{% extends "_layout.njk" %}
{% from "macros/loading.njk" import renderLoadingPage %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [{
      text: "Home",
      href: "/"
    },{
      text: "Payment holds",
      href: "/payment-holds"
    }, {
      text: "Add/remove payment holds in bulk",
      href: "/payment-holds/bulk"
    }, {
      text: "Processing bulk upload"
    }]
  })}}
{% endblock %}

{% block content %}
  <main class="govuk-main-wrapper " id="main-content" role="main">
    {{ renderLoadingPage(
      jobId=jobId,
      checkUrl="/loading/" + jobId,
      redirectUrl="/payment-holds",
      title="Processing bulk upload",
      statusMessage="We're processing your payment holds. This can take a few minutes for large files.",
      completedMessage="Your payment holds have been successfully processed. You will be redirected to the payment holds page.",
      errorMessage="We were unable to process your payment holds. Please try again."
    ) }}
  </main>
{% endblock %}
