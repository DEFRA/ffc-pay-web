{% extends '_layout.njk' %}
{% from "./macros/logout.njk" import logout %}

{% block content %}
  <style>
    .govuk-cards {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      margin-bottom: 15px;
      padding: 0;
    }

    .govuk-cards--2__item {
      flex: 1 1 50%;
      margin-bottom: 40px;
      position: relative;
      padding: 25px;
      list-style-type: none;
      margin-bottom: 0;
    }

    .card__heading {
      margin-top: 0;
      margin-bottom: 15px;
    }

    .govuk-u-hidden {
      visibility: hidden;
      pointer-events: none;
    }

    /* Mobile layout: stack cards vertically */
    @media (max-width: 640px) {
      .govuk-cards {
        flex-direction: column;
        flex-wrap: nowrap;
        margin-bottom: 30px;
      }

      .govuk-cards--2__item {
        flex: 1 1 100%;
      }
    }
  </style>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">{{ serviceName }}</h1>

      {% set cardGroups = [] %}
      {% for i in range(0, cards | length, 2) %}
        {% set cardGroups = cardGroups.concat([cards.slice(i, i + 2)]) %}
      {% endfor %}

      {% for group in cardGroups %}
        <div class="govuk-cards govuk-cards--2">
          {% for card in group %}
            <div class="govuk-cards--2__item govuk-card--dashboard dashboard-card">
              <h2 class="govuk-heading-m card__heading">{{ card.title }}</h2>
              <ul class="govuk-list">
                {% for link in card.links %}
                  <li>
                    <a href="{{ link.href }}" class="govuk-link">{{ link.text }}</a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endfor %}
          {% if group | length == 1 %}
            <div class="govuk-cards--2__item govuk-u-hidden"></div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endblock %}
