{% extends "_layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% set pageTitle = model.title.text %}

{% block pageTitle %}{{ model.title.text }} - {{ serviceName }}{% endblock %}

{% block beforeContent %}
  {{ govukBackLink({
    text: "Back",
    href: "/"
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      <h1 class="govuk-heading-l">{{ model.title.text }}</h1>

      <p class="govuk-body">
        Access to individual pages is managed by Entra ID groups. While all pages are listed, you may be unable to access all of the pages depending on the Entra ID groups your account is assigned to.
      </p>

      {% for section in model.sections %}
        <h2 class="govuk-heading-m">{{ section.title }}</h2>
        <ul class="govuk-list govuk-list--bullet">
          {% for link in section.links %}
            <li><a href="{{ link.href }}">{{ link.text }}</a></li>
          {% endfor %}
        </ul>
      {% endfor %}
    </div>
  </div>
{% endblock %}
