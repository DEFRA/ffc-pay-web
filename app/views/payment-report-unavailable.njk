{% extends '_layout.njk' %}

{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "macros/unavailable.njk" import contentBlock %}

{% set pageTitle = "Payment report unavailable" %}

{% block pageTitle %}{{ pageTitle }} - {{ serviceName }}{% endblock %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [{
      text: "Home",
      href: "/"
    },{
      text: "Reports",
      href: "/report-list"
    }, {
      text: pageTitle
    }]
  })}}
{% endblock %}

{% block content %}
  {{ contentBlock(pageTitle, "The payment report is not currently available.  Please try again later.") }}
{% endblock %}