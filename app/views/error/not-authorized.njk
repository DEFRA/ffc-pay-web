{% extends '_layout.njk' %}

{% set pageTitle = "Sorry, you are not authorised to perform this action" %}

{% block pageTitle %}{{ pageTitle }} - {{ serviceName }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>
      <a class="govuk-link" href="/login">Login using another account</a>
    </div>
  </div>
{% endblock %}
